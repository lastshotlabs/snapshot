---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 | Snapshot Docs</title>
    <meta
      name="description"
      content="The requested Snapshot Docs page could not be found."
    />
    <style>
      :root {
        color-scheme: light;
        --page-bg: #f5f7fb;
        --card-bg: #ffffff;
        --text: #132033;
        --muted: #50627a;
        --border: #d7e0ea;
        --accent: #1459c7;
        --accent-strong: #0b3f92;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 32px;
        background:
          radial-gradient(circle at top, rgba(20, 89, 199, 0.12), transparent 32%),
          linear-gradient(180deg, #f9fbff 0%, var(--page-bg) 100%);
        color: var(--text);
        font-family:
          "Segoe UI", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          sans-serif;
      }

      main {
        width: min(640px, 100%);
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 32px;
        box-shadow: 0 20px 60px rgba(13, 29, 56, 0.08);
      }

      h1 {
        margin: 0 0 12px;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
      }

      p {
        margin: 0 0 16px;
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.6;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
      }

      a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid var(--border);
        color: var(--text);
        text-decoration: none;
        font-weight: 600;
        background: #fff;
      }

      a[data-primary="true"] {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
      }

      a:hover {
        border-color: var(--accent-strong);
      }

      a[data-primary="true"]:hover {
        background: var(--accent-strong);
      }
    </style>
  </head>
  <body>
    <main>
      <p>Snapshot Docs</p>
      <h1>Page Not Found</h1>
      <p>
        The page you requested does not exist. Use the main entrypoints below to
        get back to the documented Snapshot surfaces that are current on `main`.
      </p>
      <nav>
        <a href="/" data-primary="true">Docs Home</a>
        <a href="/start-here/">Choose Your Path</a>
        <a href="/reference/">Reference Overview</a>
      </nav>
    </main>
  </body>
</html>

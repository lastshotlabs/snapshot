{
  "name": "@lastshotlabs/snapshot",
  "version": "0.1.0",
  "description": "React frontend framework for bunshot-powered backends",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "bin": {
    "snapshot": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    ".oclif.manifest.json"
  ],
  "oclif": {
    "bin": "snapshot",
    "dirname": "snapshot",
    "commands": "./dist/cli/commands",
    "topicSeparator": " "
  },
  "scripts": {
    "build": "tsup && oclif manifest",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "@tanstack/react-router": ">=1.0.0",
    "@unhead/react": ">=2.0.0",
    "jotai": ">=2.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "vite": ">=5.0.0",
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.114.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@unhead/react": "^2.0.0",
    "happy-dom": "^20.8.9",
    "jotai": "^2.0.0",
    "jsdom": "^29.0.1",
    "oclif": "^4.22.96",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@oclif/core": "^4.10.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-mention": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "highlight.js": "^11.11.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  }
}

{
  "name": "@lastshotlabs/snapshot",
  "version": "0.1.0",
  "description": "React frontend framework for bunshot-powered backends",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "import": "./dist/manifest/index.js",
      "require": "./dist/manifest/index.cjs"
    },
    "./generation": {
      "types": "./dist/generation/index.d.ts",
      "import": "./dist/generation/index.js",
      "require": "./dist/generation/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "bin": {
    "snapshot": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    ".oclif.manifest.json"
  ],
  "oclif": {
    "bin": "snapshot",
    "dirname": "snapshot",
    "commands": "./dist/cli/commands",
    "topicSeparator": " "
  },
  "scripts": {
    "build": "tsup && oclif manifest",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "@tanstack/react-router": ">=1.0.0",
    "@unhead/react": ">=2.0.0",
    "jotai": ">=2.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "vite": ">=5.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.114.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@unhead/react": "^2.0.0",
    "eslint": "^10.1.0",
    "jotai": "^2.0.0",
    "oclif": "^4.22.96",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@oclif/core": "^4.10.2"
  }
}
